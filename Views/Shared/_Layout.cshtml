@{
    var theme = Context.Request.Cookies["Theme"] ?? "light";
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Todo App</title>

    <!-- Bootstrap Core -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" >

</head>
<style>
    /* ================================
       Smooth Theme Transitions
    ================================ */
    body, .card, .list-group-item, .btn, input, textarea, select {
        transition: background-color .35s ease, color .35s ease, border-color .35s ease;
    }

    html, body {
        transition: background-color .35s ease, color .35s ease;
    }

    .btn:hover {
        transition: background-color .25s ease, color .25s ease, border-color .25s ease;
    }

    /* ================================
       Light Theme (Default)
    ================================ */
    body.light .card {
        background: #ffffff;
        color: #000;
    }

    body.light .btn-primary {
        --bs-btn-bg: #0d6efd;
    }

    /* ================================
       Focus (Dark) Theme
    ================================ */
    body.focus .card,
    body.dark .card {
        background: #1e1e1e;
        color: #ffffff !important;
        border: 1px solid #333;
    }

    body.focus .card-title,
    body.dark .card-title {
        color: #ffffff !important;
    }

    body.focus .text-muted,
    body.dark .text-muted {
        color: #cfcfcf !important;
    }

    body.focus .btn-outline-secondary,
    body.dark .btn-outline-secondary {
        color: #ffffff;
        border-color: #aaaaaa;
    }

        body.focus .btn-outline-secondary:hover,
        body.dark .btn-outline-secondary:hover {
            background: #ffffff;
            color: #000;
        }

    body.focus {
        background: #121212;
        color: white;
    }

        body.focus .list-group-item {
            background: #2c2c2c;
            color: white;
        }

        body.focus .btn {
            border-color: white;
            color: white;
        }

            body.focus .btn:hover {
                background: white;
                color: black;
            }

    /* ================================
       Morning Theme (Warm)
    ================================ */
    body.morning {
        background: #fff9e6;
    }

        body.morning .card {
            background: #fff3cd;
        }

        body.morning .btn {
            background: #ffda6a;
            border: none;
        }

    /* ================================
       Evening Theme (Calm Blue)
    ================================ */
    body.evening {
        background: #e9f2ff;
    }

        body.evening .card {
            background: #cfe2ff;
        }

        body.evening .btn {
            background: #0d6efd;
            border: none;
            color: white;
        }

    /* ================================
       High Contrast Theme
    ================================ */
    body.contrast {
        background: white;
        color: black;
    }

        body.contrast .card {
            border: 2px solid black;
        }

        body.contrast .btn {
            background: black;
            color: white;
        }

    /* ================================
       Misc Elements
    ================================ */
    .todo-text {
/*         border-radius: 25px; */
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .theme-toggle .btn {
        width: 32px;
        height: 32px;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0;
        font-size: 14px;
        border-radius: 50% !important;
        transition: transform .2s;
    }

        .theme-toggle .btn:hover {
            transform: scale(1.15);
        }

    /* Highlight active theme button */
    body.light .theme-btn[data-theme="light"],
    body.focus .theme-btn[data-theme="focus"],
    body.morning .theme-btn[data-theme="morning"],
    body.evening .theme-btn[data-theme="evening"],
    body.contrast .theme-btn[data-theme="contrast"] {
        outline: 3px solid #0d6efd;
    }

    /* Theme Dropdown Icon */
    #themeDropdown {
        border: none;
        font-size: 1.2rem;
        padding: 0.3rem 0.5rem;
    }

    /* Light Theme */
    body.light .btn-outline-light {
        color: #0d6efd;
        border-color: #0d6efd;
    }

        body.light .btn-outline-light:hover {
            background: #0d6efd;
            color: #fff;
        }

    /* Focus (Dark) Theme */
    body.focus .btn-outline-light {
        color: #000;
        border-color: #ffffff;
    }

    /* Morning Theme (Warm Yellow) */
    body.morning .btn-outline-light {
        /* color: #c77d00; */
        border-color: #c77d00;
    }
/* 
        body.morning .btn-outline-light:hover {
            background: #c77d00;
            color: #fff;
        } */

    /* Evening Theme (Calm Blue) */
    body.evening .btn-outline-light {
        color: #fff;
        border-color: #0d6efd;
    }

    /* High Contrast Theme */
    body.contrast .btn-outline-light {
        color: #fff;
        border-color: #000;
    }

        body.contrast .btn-outline-light:hover {
            background: #000;
            
        }

    /* Light Theme: Black outline */
     body.light a.btn[href="/Todo"] {
        border: 1px solid #000;
        color: #000;
        background: transparent;
    }

       body.light a.btn[href="/Todo"]:hover {
            background: #000;
            color: #fff;
        }

    /* Dark / Focus Theme */
    body.focus a.btn[href="/Todo"],
    body.dark a.btn[href="/Todo"] {
        border: 1px solid #fff;
        color: #fff;
        background: transparent;
    }

        body.focus a.btn[href="/Todo"]:hover,
        body.dark a.btn[href="/Todo"]:hover {
            background: #fff;
            color: #000;
        }

    /* Morning Theme */
    body.morning a.btn[href="/Todo"] {
        color: #fff;
    }

    body.light .btn.borderline {
        border: 1px solid #000;
        color: #000;
        background: transparent;
    }

        body.light .btn.borderline:hover {
            background: #000;
            color: #fff;
        }
</style>

<body class="@theme">

    <nav class="navbar navbar-expand-lg navbar-dark bg-black">
        <div class="container">
            <a class="navbar-brand" href="/">DailyDo</a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">

                    <!-- ?? Theme Menu Icon Dropdown -->
                    <li class="nav-item dropdown ms-3">
                        <a class="nav-link dropdown-toggle p-0" href="#" id="themeDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-palette-fill fs-5 text-light"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="themeDropdown" style="min-width: 180px;">
                            <li>
                                <form method="post" action="/Todo/SetTheme">
                                    <input type="hidden" name="theme" value="light" />
                                    <button type="submit" class="dropdown-item d-flex align-items-center">
                                        <i class="bi bi-sun-fill text-warning me-2"></i> Light
                                    </button>
                                </form>
                            </li>
                            <li>
                                <form method="post" action="/Todo/SetTheme">
                                    <input type="hidden" name="theme" value="focus" />
                                    <button type="submit" class="dropdown-item d-flex align-items-center">
                                        <i class="bi bi-moon-stars-fill text-secondary me-2"></i> Focus
                                    </button>
                                </form>
                            </li>
                            <li>
                                <form method="post" action="/Todo/SetTheme">
                                    <input type="hidden" name="theme" value="morning" />
                                    <button type="submit" class="dropdown-item d-flex align-items-center">
                                        <i class="bi bi-sunrise-fill text-warning me-2"></i> Morning
                                    </button>
                                </form>
                            </li>
                            <li>
                                <form method="post" action="/Todo/SetTheme">
                                    <input type="hidden" name="theme" value="evening" />
                                    <button type="submit" class="dropdown-item d-flex align-items-center">
                                        <i class="bi bi-cloud-sun-fill text-primary me-2"></i> Evening
                                    </button>
                                </form>
                            </li>
                            <li>
                                <form method="post" action="/Todo/SetTheme">
                                    <input type="hidden" name="theme" value="contrast" />
                                    <button type="submit" class="dropdown-item d-flex align-items-center">
                                        <i class="bi bi-circle-half text-dark me-2"></i> High Contrast
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- Bootstrap Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
